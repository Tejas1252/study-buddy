# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Which AI backend to use: "gemini" (cloud, free tier) or "ollama" (local).
AI_PROVIDER=gemini

# Google Gemini API key (get one free at https://aistudio.google.com/app/apikey).
# Required when AI_PROVIDER=gemini.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Ollama (only needed when AI_PROVIDER=ollama, i.e. running locally) ---
OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Server port (Render sets this automatically in production).
PORT=5000

# Comma-separated list of allowed browser origins for CORS.
# Leave blank to allow all origins (fine for local dev).
# In production set this to your Netlify site, e.g. https://your-app.netlify.app
ALLOWED_ORIGIN=
