# Copy this file to ".env" for local overrides, or set these in Netlify's
# "Environment variables" dashboard for production builds.

# Base URL of the backend API.
# Local dev default (used if this is unset): http://localhost:5000/api
# Production: https://your-backend.onrender.com/api
REACT_APP_API_BASE_URL=http://localhost:5000/api
